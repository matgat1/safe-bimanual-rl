<mujoco model="tray">
  <default>
    <default class="tray_part">
      <geom rgba="0.3 0.3 0.3 1" contype="1" conaffinity="1"/>
    </default>
  </default>

  <worldbody>

    <body name="tray" pos="-0.6 0.0 0.83" euler="0 0 1.57">
      <freejoint/>
      <geom name="tray_base" class="tray_part" type="box" size="0.2 0.15 0.005"
            solref="0.004 1" solimp="0.99 0.999 1e-5"/>

      <geom name="tray_wall_front" class="tray_part" type="box" size="0.2 0.005 0.02" pos="0  0.15 0.015"/>
      <geom name="tray_wall_back"  class="tray_part" type="box" size="0.2 0.005 0.02" pos="0 -0.15 0.015"/>
      <geom name="tray_wall_right" class="tray_part" type="box" size="0.005 0.15 0.02" pos=" 0.2 0 0.015"/>
      <geom name="tray_wall_left"  class="tray_part" type="box" size="0.005 0.15 0.02" pos="-0.2 0 0.015"/>

      <!-- Right handle -->
      <geom class="tray_part" type="box" size="0.007 0.007 0.025" pos=" 0.207  0.05 0.055"/>
      <geom class="tray_part" type="box" size="0.007 0.007 0.025" pos=" 0.207 -0.05 0.055"/>
      <body name="right_handle" pos=" 0.207 0 0.08">
        <geom name="right_handle_bar" class="tray_part" type="cylinder" size="0.007 0.057" euler="1.57 0 0"/>
        <site name="right_grasp_target" pos="0.05 0 0" size="0.01" rgba="1 0 0 0.5"/>
      </body>

      <!-- Left handle -->
      <geom class="tray_part" type="box" size="0.007 0.007 0.025" pos="-0.207  0.05 0.055"/>
      <geom class="tray_part" type="box" size="0.007 0.007 0.025" pos="-0.207 -0.05 0.055"/>
      <body name="left_handle" pos="-0.207 0 0.08">
        <geom name="left_handle_bar" class="tray_part" type="cylinder" size="0.007 0.057" euler="1.57 0 0"/>
        <site name="left_grasp_target" pos="-0.05 0 0" size="0.01" rgba="0 0 1 0.5"/>
      </body>
    </body>

    <body name="cube" pos="-0.6 0.0 0.9">
      <freejoint/>
      <geom name="cube" type="box" size="0.025 0.025 0.025" rgba="0.063 0.529 0.318 1" mass="0.1"
            contype="1" conaffinity="1"
            solref="0.004 1" solimp="0.99 0.999 1e-5"/>
    </body>

  </worldbody>

</mujoco>
